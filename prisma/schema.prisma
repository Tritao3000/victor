// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Auth models (Better Auth compatible)
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          UserRole  @default(CUSTOMER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Customer fields
  phone         String?
  address       String?
  city          String?
  state         String?
  zipCode       String?

  // Stripe
  stripeCustomerId String? @unique

  // Link to service provider profile (if role is SERVICE_PROVIDER)
  serviceProviderId String?           @unique
  serviceProvider   ServiceProvider?  @relation(fields: [serviceProviderId], references: [id])

  sessions      Session[]
  accounts      Account[]
  bookings      Booking[]
  reviews       Review[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Marketplace models
enum UserRole {
  CUSTOMER
  SERVICE_PROVIDER
}

enum ServiceType {
  PLUMBING
  ELECTRICAL
}

enum ProviderStatus {
  PENDING_VERIFICATION
  VERIFIED
  SUSPENDED
}

enum BookingStatus {
  REQUESTED
  MATCHING
  MATCHED
  PROVIDER_EN_ROUTE
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BookingUrgency {
  EMERGENCY   // 1.5x multiplier
  TODAY       // 1.2x multiplier
  SCHEDULED   // 1.0x multiplier
}

enum PaymentStatus {
  PENDING
  REQUIRES_PAYMENT
  PROCESSING
  CAPTURED
  REFUNDED
  PARTIALLY_REFUNDED
  FAILED
  CANCELLED
}

model ServiceProvider {
  id                String          @id @default(cuid())
  email             String          @unique
  name              String
  phone             String
  bio               String?
  image             String?

  // Service capabilities
  serviceTypes      ServiceType[]
  specialties       String[]        // e.g., ["leak repair", "drain cleaning"]

  // Service area
  city              String
  state             String
  serviceRadius     Int             @default(25) // miles

  // Verification and status
  verificationStatus ProviderStatus @default(PENDING_VERIFICATION)
  verifiedAt        DateTime?
  licenseNumber     String?
  insuranceExpiry   DateTime?

  // Stripe Connect
  stripeConnectedAccountId String?  @unique
  stripeOnboardingComplete Boolean  @default(false)

  // Ratings
  rating            Float           @default(0)
  totalReviews      Int             @default(0)

  // Availability
  isActive          Boolean         @default(true)
  availableHours    Json?           // Flexible schedule data

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user              User?
  bookings          Booking[]
  services          Service[]
}

model Service {
  id                String          @id @default(cuid())
  name              String
  description       String
  serviceType       ServiceType
  category          String          // e.g., "Leak Repair", "Outlet Installation"

  // Pricing
  basePrice         Float           // Base price in dollars
  priceUnit         String          @default("per job") // "per job", "per hour"
  estimatedDuration Int?            // minutes

  // Provider offering this service
  providerId        String
  provider          ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  bookings          Booking[]

  @@index([serviceType, category])
  @@index([providerId])
}

// Platform-level service catalog (decoupled from individual providers)
model ServiceCategory {
  id                String          @id @default(cuid())
  serviceType       ServiceType
  name              String          // e.g., "Leak Repair", "Outlet Installation"
  description       String
  basePrice         Float           // Base price in euros
  estimatedDuration Int             // minutes

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  bookings          Booking[]

  @@unique([serviceType, name])
  @@index([serviceType])
}

model Booking {
  id                String          @id @default(cuid())

  // Customer
  customerId        String
  customer          User            @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // Provider (nullable — assigned by matching, not by customer)
  providerId        String?
  provider          ServiceProvider? @relation(fields: [providerId], references: [id], onDelete: Restrict)

  // Service (nullable — legacy field, kept for backward compat)
  serviceId         String?
  service           Service?        @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  // Uber-style booking fields
  serviceType       ServiceType     // PLUMBING or ELECTRICAL
  serviceCategoryId String?
  serviceCategory   ServiceCategory? @relation(fields: [serviceCategoryId], references: [id])
  urgency           BookingUrgency  @default(SCHEDULED)

  // Booking details
  status            BookingStatus   @default(REQUESTED)
  scheduledFor      DateTime
  completedAt       DateTime?

  // Time window (customer's preferred window)
  preferredTimeStart DateTime?
  preferredTimeEnd   DateTime?

  // Location
  address           String
  city              String
  state             String
  zipCode           String
  locationNotes     String?         // e.g., "Gate code: 1234"

  // Pricing
  estimatedPrice    Float           // Upfront price shown to customer
  quotedPrice       Float?          // Final quoted price once matched
  finalPrice        Float?          // Actual cost after job completion

  // Problem description
  problemDescription String
  notes             String?         // Provider notes

  // Matching
  matchedAt         DateTime?       // When provider was matched
  providerAcceptedAt DateTime?      // When provider accepted
  estimatedArrival  DateTime?       // Provider ETA
  matchAttempts     Int             @default(0)

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  review            Review?
  payment           Payment?

  @@index([customerId])
  @@index([providerId])
  @@index([status])
  @@index([scheduledFor])
  @@index([serviceType, city])
}

model Review {
  id                String          @id @default(cuid())

  bookingId         String          @unique
  booking           Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  customerId        String
  customer          User            @relation(fields: [customerId], references: [id], onDelete: Cascade)

  rating            Int             // 1-5 stars
  comment           String?

  // Moderation
  isFlagged         Boolean         @default(false)
  flagReason        String?

  // Provider can also rate customer
  providerRating    Int?            // 1-5 stars (optional)
  providerComment   String?

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([customerId])
  @@index([rating])
  @@index([isFlagged])
}

model Payment {
  id                     String        @id @default(cuid())

  bookingId              String        @unique
  booking                Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  // Stripe
  stripePaymentIntentId  String        @unique
  stripeTransferId       String?       // Transfer to provider connected account

  // Amounts in cents
  amount                 Int           // Total charged to customer (cents)
  platformFee            Int           // Victor's cut (cents)
  providerPayout         Int           // Provider's share (cents)
  currency               String        @default("eur")

  status                 PaymentStatus @default(PENDING)

  // Refund tracking
  refundedAmount         Int           @default(0) // Total refunded (cents)
  refundReason           String?

  capturedAt             DateTime?
  refundedAt             DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@index([status])
  @@index([stripePaymentIntentId])
}
